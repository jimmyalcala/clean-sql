#!/bin/bash
set -e

if [ -z "$1" ]; then
    echo "Usage: restore <sql-file>"
    echo "  1. Fixes reserved word issues with clean-sql"
    echo "  2. Imports into MySQL"
    echo "  3. Moves files to restored_sql/"
    exit 1
fi

DB_HOST="${DB_HOST:-localhost}"
DB_USER="${DB_USER:?Set DB_USER environment variable}"
DB_PASS="${DB_PASS:?Set DB_PASS environment variable}"
DB_NAME="${DB_NAME:?Set DB_NAME environment variable}"

FILE="$1"
DIR="$(dirname "$FILE")"
BASENAME="$(basename "$FILE" .sql)"
CLEAN_FILE="${DIR}/${BASENAME}_clean.sql"
RESTORE_DIR="${DIR}/restored_sql"

if [ ! -f "$FILE" ]; then
    echo "Error: file not found: $FILE"
    exit 1
fi

# Step 1: Clean
echo "==> Cleaning SQL file..."
clean-sql "$FILE" --disable-fk -o "$CLEAN_FILE"

# Step 2: Import
echo "==> Importing into MySQL..."
mysql -f -h"$DB_HOST" -u"$DB_USER" -p"$DB_PASS" "$DB_NAME" < "$CLEAN_FILE"
echo "==> Import complete."

# Step 3: Move to restored_sql/
mkdir -p "$RESTORE_DIR"
mv "$FILE" "$RESTORE_DIR/"
mv "$CLEAN_FILE" "$RESTORE_DIR/"
echo "==> Files moved to ${RESTORE_DIR}/"
echo "Done."
